{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "astro",
	"installCommand": "pnpm install",
	"buildCommand": "pnpm build",
	"outputDirectory": "dist",
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*)\\.(jpg|jpeg|png|gif|svg|webp|ico|pdf|woff2?)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
