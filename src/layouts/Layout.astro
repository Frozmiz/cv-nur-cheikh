---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Nur Cheikh Waez | Odontóloga General' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="CV profesional de Nur Cheikh Waez, Odontóloga General."
		/>
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<main class="mx-auto max-w-5xl px-6 pb-24 md:px-12 md:pb-32">
			<slot />
		</main>
	</body>
</html>
