---
import { idiomas, odontologia, softSkills } from '../config/skills';
import SkillIcon from './SkillIcon.astro';

const pillClass =
	'inline-block rounded-lg border border-teal-100 bg-white px-4 py-2 text-sm font-medium text-teal-800 shadow-sm';

const blockClass = 'rounded-2xl bg-slate-100/70 px-6 py-8 md:px-8 md:py-10';
---

<section class="py-16 md:py-24" aria-labelledby="skills-heading">
	<h2 id="skills-heading" class="mb-10 text-center text-3xl font-semibold text-slate-800 md:mb-16">
		Especialidades y Competencias
	</h2>

	<div class="flex flex-col gap-10">
		<div class={blockClass}>
			<h3 class="mb-6 flex items-center gap-2.5 text-2xl font-medium text-slate-800">
				<SkillIcon name="stethoscope" class="h-6 w-6 text-teal-600" />
				Competencias Clínicas
			</h3>
			<ul class="flex flex-wrap gap-3">
				{
					odontologia.map((item) => (
						<li>
							<span class={pillClass}>{item}</span>
						</li>
					))
				}
			</ul>
		</div>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
			<article class={blockClass}>
				<h3 class="mb-6 flex items-center gap-2.5 text-lg font-medium text-slate-800">
					<SkillIcon name="user" class="text-teal-600" />
					Perfil Profesional
				</h3>
				<ul class="flex flex-wrap gap-3">
					{
						softSkills.map((item) => (
							<li>
								<span class={pillClass}>{item}</span>
							</li>
						))
					}
				</ul>
			</article>

			<article class={blockClass}>
				<h3 class="mb-6 flex items-center gap-2.5 text-lg font-medium text-slate-800">
					<SkillIcon name="globe" class="text-teal-600" />
					Idiomas
				</h3>
				<ul class="flex flex-wrap gap-3">
					{
						idiomas.map((item) => (
							<li>
								<span class={pillClass}>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
		</div>
	</div>
</section>
