---
interface Props {
	title: string;
	subtitle: string;
	date: string;
	type: 'experiencia' | 'educación';
}

const { title, subtitle, date, type } = Astro.props;
---

<article class="relative border-l-2 border-slate-200 pb-10 last:pb-0" data-type={type}>
	<span
		class="absolute top-1.5 -left-[9px] h-4 w-4 rounded-full border-4 border-teal-500 bg-white md:-left-[11px] md:top-2 md:h-5 md:w-5"
		aria-hidden="true"
	></span>
	<div class="ml-6 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
		<h4 class="text-lg font-medium text-text-primary">{title}</h4>
		<p class="mt-1 text-teal-600">{subtitle}</p>
		<time class="mt-3 block text-sm text-slate-500" datetime={date}>{date}</time>
	</div>
</article>
