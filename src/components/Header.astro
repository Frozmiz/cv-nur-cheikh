---
import ToothIcon from './ToothIcon.astro';
---

<header
	class="sticky top-0 z-50 w-full border-b border-slate-100 bg-white/80 py-5 backdrop-blur-md md:py-6"
>
	<div
		class="mx-auto flex max-w-5xl items-center justify-between px-6 md:px-12"
	>
		<a href="/" class="flex items-center gap-3 text-[#1E293B]">
			<ToothIcon class="h-8 w-8 text-teal-600 md:h-9 md:w-9" />
			<span class="text-2xl tracking-tight md:text-3xl">
				<span class="font-bold">NUR</span>
				<span class="font-light"> CHEIKH WAEZ</span>
			</span>
		</a>
		<a
			href="#contacto"
			class="rounded-full bg-teal-50 px-6 py-2.5 text-sm font-medium text-teal-700 transition-colors hover:bg-teal-100"
		>
			Contacto
		</a>
	</div>
</header>
