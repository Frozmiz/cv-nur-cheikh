---
import ToothIcon from './ToothIcon.astro';

const specialties = [
	'Preventiva',
	'Conservadora',
	'Periodoncia',
	'Prótesis',
	'Odontopediatría',
];
---

<section
	class="relative overflow-hidden flex flex-col items-center gap-8 pt-12 pb-12 md:flex-row md:items-center md:gap-12 md:pt-20 md:pb-24 lg:pb-32"
	aria-labelledby="hero-heading"
>
	<div
		class="pointer-events-none absolute -right-20 top-10 -z-10 h-96 w-96 text-slate-200/80 opacity-40"
		aria-hidden="true"
	>
		<ToothIcon class="h-full w-full" />
	</div>

	<div class="order-1 flex shrink-0 justify-center md:order-2 md:justify-end">
		<img
			src="/nur-pro.png"
			alt="Nur Cheikh Waez, Odontóloga General"
			width="640"
			height="640"
			class="h-48 w-48 rounded-full object-cover object-center shadow-xl shadow-slate-200/50 ring-8 ring-white md:h-64 md:w-64"
		/>
	</div>

	<div class="order-2 flex flex-1 flex-col items-center text-center md:order-1 md:items-start md:text-left">
		<h1
			id="hero-heading"
			class="text-4xl font-semibold text-text-primary md:text-6xl"
		>
			Odontóloga General
		</h1>

		<p class="mt-4 text-sm leading-relaxed text-text-secondary md:text-base">
			<span>📍 Pozuelo de Alarcón, Madrid</span>
			<span class="mx-2 hidden sm:inline" aria-hidden="true">|</span>
			<span class="mt-1 block sm:mt-0 sm:inline">
				<a href="tel:+34697931294" class="transition-opacity hover:opacity-75">
					📞 +34 697 93 12 94
				</a>
			</span>
			<span class="mx-2 hidden sm:inline" aria-hidden="true">|</span>
			<span class="mt-1 block sm:mt-0 sm:inline">
				<a
					href="mailto:nurcheb1b16@gmail.com"
					class="transition-opacity hover:opacity-75"
				>
					✉️ nurcheb1b16@gmail.com
				</a>
			</span>
		</p>

		<div class="mt-8 max-w-2xl text-base leading-relaxed text-text-primary md:text-lg">
			<p>
				Graduada en <span class="font-semibold text-slate-900">Odontología</span> con
				experiencia previa en clínicas dentales. Motivada por seguir desarrollándome
				profesionalmente en{' '}
				<span class="font-semibold text-slate-900">Odontología General</span>.
			</p>

			<p class="mt-4 text-text-secondary">
				De fácil adaptación, rápido aprendizaje y con un enfoque profundamente empático
				hacia el paciente.
			</p>

			<div class="mt-6">
				<p class="mb-3 text-sm font-medium text-text-secondary">
					Especialidades
				</p>
				<ul
					class="flex flex-wrap justify-center gap-2 md:justify-start"
					aria-label="Especialidades en odontología general"
				>
					{
						specialties.map((specialty) => (
							<li>
								<span class="inline-block rounded-full bg-teal-50 px-3.5 py-1.5 text-sm font-medium text-teal-600">
									{specialty}
								</span>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div class="mt-8 flex flex-col gap-4 sm:mt-10 sm:flex-row sm:gap-5">
			<a
				href="mailto:nurcheb1b16@gmail.com?subject=Contacto%20desde%20CV%20Web"
				class="inline-flex items-center justify-center rounded-full bg-teal-600 px-8 py-3 font-medium text-white transition-colors hover:bg-teal-700"
			>
				Contactar
			</a>
			<a
				href="/cv-nur-cheikh.pdf"
				download
				class="inline-flex items-center justify-center rounded-full border border-teal-600 bg-transparent px-8 py-3 font-medium text-teal-600 transition-colors hover:bg-teal-50"
			>
				Descargar CV
			</a>
		</div>
	</div>
</section>
